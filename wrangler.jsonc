{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "keeva-game",
  "compatibility_date": "2026-05-11",
  "main": "src/index.js",
  "routes": [
    {
      "pattern": "keeva-game.arckemistry.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./",
    "not_found_handling": "single-page-application"
  }
}
